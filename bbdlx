    {"q": "Қайсысы логикалық қателік?", "options": ["A. Факт", "B. Сабан қарақшы", "C. Зерттеу", "D. Аксиома"], "correct": 1, "exp": "Сабан қарақшы - аргументті бұрмалау."},
