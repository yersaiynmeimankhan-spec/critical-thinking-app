    # Мәзір таңдау
    menu_options = ["Талдау (Тест)", "🏆 Көшбасшылар"]
    if st.session_state.is_organizer:
        menu_options.append("⚙️ Админ панель")
        
    choice = st.sidebar.selectbox("Бөлімді таңдаңыз:", menu_options)
    
    st.sidebar.markdown("---")
    if st.sidebar.button("Шығу (Logout)"):
        st.session_state.auth = False
        st.session_state.is_organizer = False
        st.session_state.clear()
        st.rerun()

# --- ЛОГИКА ЭКРАНОВ ---

# ЭКРАН 1: ТІРКЕЛУ
if not st.session_state.auth:
    st.markdown("<h1 style='text-align: center;'>Advanced Critical Thinking</h1>", unsafe_allow_html=True)
    with st.container():
        st.markdown('<div class="glass-card">', unsafe_allow_html=True)
        st.subheader("Кіру / Вход")
        name = st.text_input("Атыңыз")
        email = st.text_input("Email (Организатор болсаңыз, admin@test.com қолданыңыз)")
        if st.button("Кіру"):
            if name and email:
                st.session_state.user_name = name
                st.session_state.user_email = email
                st.session_state.auth = True
                # Организатор ма, жоқ па, тексереміз
                if email == ORGANIZER_EMAIL:
                    st.session_state.is_organizer = True
                
                # Симуляция: Егер бұл жаңа қолданушы болса, "деректер қорына" қосамыз
                if email not in st.session_state.db_users['email'].values and email != ORGANIZER_EMAIL:
                     new_user = pd.DataFrame([{"name": name, "email": email, "score": 0, "level": 1}])
                     st.session_state.db_users = pd.concat([st.session_state.db_users, new_user], ignore_index=True)

                st.rerun()
            else:
                st.warning("Өрістерді толтырыңыз!")
        st.markdown('</div>', unsafe_allow_html=True)

# АВТОРИЗАЦИЯДАН ӨТКЕННЕН КЕЙІН
else:
    # --- ПАРАҚША: КӨШБАСШЫЛАР (ПЬЕДЕСТАЛ) ---
    if choice == "🏆 Көшбасшылар":
        st.markdown("<h2 style='text-align: center;'>🏆 Көшбасшылар тақтасы</h2>", unsafe_allow_html=True)
        st.markdown("<p style='text-align: center; color: rgba(255,255,255,0.6);'>Ең үздік 5 ойыншы</p>", unsafe_allow_html=True)
        
        # Симуляция деректерін ұпай бойынша сұрыптаймыз (кему ретімен)
        leaderboard_df = st.session_state.db_users.sort_values(by='score', ascending=False).head(5)
        
        with st.container():
            st.markdown('<div class="glass-card">', unsafe_allow_html=True)
            
            for i, row in enumerate(leaderboard_df.iterrows()):
                rank = i + 1
                data = row[1]
                
                rank_class = f"rank-{rank}" if rank <= 3 else ""
                rank_icon = "🥇" if rank == 1 else "🥈" if rank == 2 else "🥉" if rank == 3 else f"{rank}."
                
                st.markdown(f'''
                    <div class="leaderboard-row">
                        <div style="display: flex; align-items: center; gap: 15px;">
                            <span class="{rank_class}" style="width: 30px; text-align: center;">{rank_icon}</span>
                            <span class="user-name">{data['name']}</span>
                        </div>
                        <span class="user-score">{data['score']} XP</span>
                    </div>
                ''', unsafe_allow_html=True)
            
            st.markdown('</div>', unsafe_allow_html=True)

    # --- ПАРАҚША: АДМИН ПАНЕЛЬ (Тек Организаторға) ---
    elif choice == "⚙️ Админ панель":
        st.markdown("<h2>🛠️ Ұйымдастырушы панелі</h2>", unsafe_allow_html=True)
        st.markdown("<p>Ойынды басқару және барлық қатысушыларды бақылау.</p>", unsafe_allow_html=True)
        
        with st.container():
            st.markdown('<div class="glass-card">', unsafe_allow_html=True)
            st.subheader("Барлық ойыншылардың тізімі")
            
            # Деректерді кесте түрінде көрсетеміз
            st.dataframe(st.session_state.db_users[['name', 'email', 'score', 'level']], use_container_width=True)
            
            col1, col2 = st.columns(2)
            with col1:
                st.write("**Жалпы ойыншылар саны:**", len(st.session_state.db_users))
            with col2:
                 target_email = st.text_input("Басқару үшін Email енгізіңіз:")

            c1, c2, c3 = st.columns(3)
            with c1:
                if st.button("Ұпайын нөлдеу (Reset)"):
                    if target_email and target_email in st.session_state.db_users['email'].values:
                         idx = st.session_state.db_users[st.session_state.db_users['email'] == target_email].index[0]
                         st.session_state.db_users.at[idx, 'score'] = 0
                         st.session_state.db_users.at[idx, 'level'] = 1
                         st.success(f"{target_email} ұпайы нөлденді!")
                         time.sleep(1)
                         st.rerun()
                    else: st.error("Email табылмады!")
            with c2:
                if st.button("🚨 Ойыншыны өшіру"):
                    if target_email and target_email in st.session_state.db_users['email'].values:
                        st.session_state.db_users = st.session_state.db_users[st.session_state.db_users['email'] != target_email]
                        st.success(f"{target_email} өшірілді!")
                        time.sleep(1)
                        st.rerun()
                    else: st.error("Email табылмады!")

            st.markdown('</div>', unsafe_allow_html=True)

    # --- ПАРАҚША: ТЕСТ (Баяғы логика) ---
    else:
        st.markdown(f"<h3>Сәлем, {st.session_state.user_name}! Миыңды шынықтыруға дайынсың ба?</h3>", unsafe_allow_html=True)
        
        if st.session_state.current_q >= len(questions):
            st.markdown("<div class='glass-card' style='text-align:center;'><h2>Керемет! Тест аяқталды.</h2></div>", unsafe_allow_html=True)
            st.stop()

        # Панель
        st.markdown(f'''
            <div class="stats-container">
                <div>Ұпай: <span class="stat-value">{st.session_state.score} XP</span></div>
                <div>Сұрақ: <span class="stat-value">{st.session_state.current_q + 1}/{len(questions)}</span></div>
            </div>
        ''', unsafe_allow_html=True)

        cur = questions[st.session_state.current_q]
        st.markdown(f'<div class="glass-card"><h3>{cur["q"]}</h3></div>', unsafe_allow_html=True)

        def press_answer(idx):
            if not st.session_state.answered:
                st.session_state.answered = True
                if idx == cur["correct"]:
                    st.session_state.score += 10
                    # Симуляция: Деректер қорындағы ұпайын жаңарту
                    if st.session_state.user_email in st.session_state.db_users['email'].values:
                         u_idx = st.session_state.db_users[st.session_state.db_users['email'] == st.session_state.user_email].index[0]
                         st.session_state.db_users.at[u_idx, 'score'] += 10
                    st.toast("Дұрыс!", icon="✅")
                else: st.toast("Қате!", icon="❌")

        col1, col2 = st.columns(2)
        with col1:
            st.button(cur["options"][0], on_click=press_answer, args=(0,))
            st.button(cur["options"][2], on_click=press_answer, args=(2,))
        with col2:
            st.button(cur["options"][1], on_click=press_answer, args=(1,))
            st.button(cur["options"][3], on_click=press_answer, args=(3,))

        if st.session_state.answered:
            st.info(cur["exp"])
            if st.button("Келесі сұрақ ➡️"):
                st.session_state.current_q += 1
                st.session_state.answered = False